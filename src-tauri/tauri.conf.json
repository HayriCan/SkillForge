{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Forge",
  "version": "0.5.0",
  "identifier": "com.barcin.skill-forge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Forge",
        "width": 1100,
        "height": 720,
        "minWidth": 700,
        "minHeight": 500,
        "backgroundColor": "#f5f4f7",
      "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5RDhFRDU4MzZEQzM3MUEKUldRYU45dzJXTzNZV1dNZGM5VHFSeGFBN2FSNHFzUjFDWnF0UU5HYmlUOVByS2krR2pzWVcxME0K",
      "endpoints": [
        "https://github.com/HayriCan/SkillForge/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
